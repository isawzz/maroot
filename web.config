<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <staticContent>
            <remove fileExtension=".yaml" />
            <mimeMap fileExtension=".yaml" mimeType="text/yaml" />
            
            <remove fileExtension=".yml" />
            <mimeMap fileExtension=".yml" mimeType="text/yaml" />
        </staticContent>
        <httpErrors errorMode="Custom">
            <remove statusCode="404" subStatusCode="-1" />
            <error statusCode="404" prefixLanguageFilePath="" path="/OaOInternal/DefaultWebs/sedoCurrent/Error404.aspx" responseMode="ExecuteURL" />
        </httpErrors>
    </system.webServer>
</configuration>
